{
  "name": "tidal-calendar",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node scripts/build.mjs && node server.js",
    "build": "node scripts/build.mjs",
    "start": "node scripts/build.mjs && node server.js",
    "mcp": "node mcp/server.js",
    "voice:dev": "tsx voice/index.ts",
    "voice:build": "tsc -p tsconfig.voice.json",
    "voice:start": "node dist-voice/index.js",
    "test:voice": "vitest run voice/__tests__"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "tsx": "^4.19.2",
    "supertest": "^7.1.1",
    "@types/express": "^5.0.0",
    "@types/supertest": "^6.0.3",
    "@types/node": "^22.10.1"
  }
}